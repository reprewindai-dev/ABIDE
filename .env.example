# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Custom integration base URLs for local or model farm endpoints
AI_INTEGRATIONS_GEMINI_BASE_URL="http://localhost:1106/modelfarm/gemini"
AI_INTEGRATIONS_OPENAI_BASE_URL="http://localhost:1106/modelfarm/openai"
# Server-side Ollama/Llama connection. In Coolify, use the Ollama service DNS name
# or an internal host URL reachable from the ABIDE container; do not use localhost
# unless Ollama runs in the same container.
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3"

# Veklom Plural Canonical Service Endpoints
VEKLOM_API_URL="https://api.veklom.com"
CAPPO_URL="https://cappo.veklom.com"
GNOMELEDGER_URL="https://pgl.veklom.com"
VNP_URL="https://vnp.veklom.com"

# Cryptographic signing keys (Milestone 1)
SEKED_HMAC_SECRET="SEKED_SYSTEM_COVENANT_SECRET"
CONSTITUTION_SIGNING_KEY="CONSTITUTION_GOVERNANCE_SECRET"
APPROVAL_TOKEN_SECRET="COVENANT_APPROVAL_TOKEN_SECRET_2026"
# Required in production for management/admin routes (approvals, projections, cache clears, repo inventory).
ADMIN_API_KEY="CHANGE_ME_IN_PRODUCTION"
# Production-only opt-in for custom remote URLs. Leave unset unless you explicitly want to allow them.
ALLOW_UNSAFE_CUSTOM_URLS="false"

# =========================================================================
# REAL-WORLD CONNECTORS & API INTEGRATIONS (Pluggable Ingress/Egress Ports)
# =========================================================================
# Set these variables to instantly replace simulated mocks with real-world infrastructure.

# Real Database Persistence:
# Provide a PostgreSQL database connection string to activate relational Drizzle ORM
DATABASE_URL=""

# Real Cryptographic Payment Settlement:
# Provide your RPC or API server endpoint to route real on-chain/off-chain transactions
X402_LEDGER_URL=""

# Real TLA+ and Z3 SMT Formal Verification:
# Provide your service endpoint running the TLA+ Model Checker TLC and Z3 SMT toolchain
VERIFICATION_SERVICE_URL=""

# Real OpenTelemetry Holographic Observability:
# Provide your standard OpenTelemetry collector gRPC/HTTP endpoint (Jaeger, Datadog, Honeycomb, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=""

