{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["connection_id", "status", "evidence_hash"],
  "properties": {
    "connection_id": { "type": "string" },
    "status": { "type": "string", "enum": ["authorized", "denied"] },
    "evidence_hash": { "type": "string" },
    "result": {
      "type": "object",
      "properties": {
        "output": { "type": "object" },
        "output_hash": { "type": "string" },
        "execution_time_ms": { "type": "integer" }
      }
    },
    "reason": { "type": "string" },
    "policy_id": { "type": "string" },
    "remediation": {
      "type": "object",
      "properties": {
        "minimum_trust_required": { "type": "integer" },
        "trust_current": { "type": "integer" },
        "approval_required": { "type": "boolean" },
        "approval_path": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "trust_delta": { "type": "integer" },
        "new_trust_score": { "type": "integer" },
        "audit_logged": { "type": "boolean" }
      }
    }
  }
}
