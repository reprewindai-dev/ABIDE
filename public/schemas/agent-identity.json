{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["agent_id", "name", "public_key", "owner_id", "trust_score"],
  "properties": {
    "agent_id": { "type": "string", "format": "uuid" },
    "name": { "type": "string" },
    "public_key": { "type": "string", "description": "Ed25519 public key of the agent (Base64)" },
    "owner_id": { "type": "string" },
    "trust_score": { "type": "integer", "minimum": 0, "maximum": 100 }
  }
}
