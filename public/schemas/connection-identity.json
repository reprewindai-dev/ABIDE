{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["connection_id", "source_agent_id", "target_agent_id", "established_at"],
  "properties": {
    "connection_id": { "type": "string", "format": "uuid" },
    "source_agent_id": { "type": "string", "format": "uuid" },
    "target_agent_id": { "type": "string", "format": "uuid" },
    "established_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["active", "terminated", "suspended"] }
  }
}
